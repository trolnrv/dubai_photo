function doPost(e) {
  const data = JSON.parse(e.postData.contents);
  const imageData = data.image;

  const base64Data = imageData.split(",")[1];

  const blob = Utilities.newBlob(
    Utilities.base64Decode(base64Data),
    "image/png",
    "photo.png"
  );

  const FOLDER_ID ="1FLZJ7hZM1SGHOnCfoDk18waJ2CVPvukX";//
  const folder = DriveApp.getFolderById(FOLDER_ID);//
  const file = folder.createFile(blob)
  //const file = DriveApp.createFile(blob);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

  const url = file.getUrl();

  const sheet = SpreadsheetApp
    .openById("1P7oM4sAkM87rDaaJtDM5WSxZW-ow5d4wA68dd8cozTo")
    .getSheetByName("Feuille 1");

  sheet.appendRow([
    new Date(),
    //url
    '=IMAGE("' + url + '")'
  ]);

  return ContentService
    .createTextOutput(JSON.stringify({ ok: true, url }))
    .setMimeType(ContentService.MimeType.JSON);
}
function doGet() {
  const randomText = "TEST_FILE_" + new Date().toISOString() + "_" + Math.random();

  const blob = Utilities.newBlob(
    randomText,
    "text/plain",
    "test.txt"
  );

  const file = DriveApp.createFile(blob);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

  return ContentService.createTextOutput(
    JSON.stringify({
      ok: true,
      url: file.getUrl()
    })
  ).setMimeType(ContentService.MimeType.JSON);
  //return ContentService
  //  .createTextOutput(JSON.stringify({ ok: true, mode: "GET OK" }))
  //  .setMimeType(ContentService.MimeType.JSON);
}
