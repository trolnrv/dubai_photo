function MatGetFolders(){
  let fichiers = {};
  const folders = DriveApp.getFolders();
  while (folders.hasNext()) {
    const folder = folders.next();
    let id = folder.getId();
    let nom = folder.getName();
    let sousElements = {};
    const subFolders = folder.getFolders();
    while (subFolders.hasNext()) {
      const subFolder = subFolders.next();
      sousElements[subFolder.getId()] = {nom: subFolder.getName()};
    }
    const files = folder.getFiles();
    while (files.hasNext()){
      const file = files.next();
      if (file.getMimeType() == 'application/vnd.google-apps.spreadsheet'){
        sousElements[file.getId()] = {nom: file.getName()};
      }
    }
    fichiers[id] = {type: "D", nom: nom, sousElements: sousElements};
  }
  const files = DriveApp.getFiles();
  while (files.hasNext()){
    const file = files.next();
    let id = file.getId();
    let nom = file.getName();
    if (file.getMimeType() == 'application/vnd.google-apps.spreadsheet'){
      fichiers[id] = {type: "F", nom: nom, feuilles: {}};
      for (const sheet of SpreadsheetApp.openById(id).getSheets()){
        fichiers[id].feuilles[sheet.getName()] = {};
      }
    }
  }
  return fichiers;
}

